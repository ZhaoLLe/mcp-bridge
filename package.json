{
  "name": "mcp-bridge",
  "version": "1.0.0",
  "type": "module",
  "description": "A dynamic MCP service bridge that supports dynamic registration of MCP capabilities",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc --outDir dist/server",
    "build:web": "vite build",
    "start": "node dist/server/index.js",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "hono": "^4.0.0",
    "ws": "^8.20.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
